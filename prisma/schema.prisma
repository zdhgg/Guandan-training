// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  currentLevel  String   @default("2")
  createdAt     DateTime @default(now())
  
  @@map("users")
}

// 比赛记录模型
model MatchRecord {
  id           String   @id @default(cuid())
  startTime    DateTime
  endTime      DateTime?
  initialHands String   // JSON 序列化数据：开局时4个玩家27张手牌
  
  // 关系：一个比赛记录有多个操作日志
  actionLogs   ActionLog[]
  
  @@map("match_records")
}

// 操作日志模型
model ActionLog {
  id          String   @id @default(cuid())
  matchId     String
  match       MatchRecord @relation(fields: [matchId], references: [id])
  stepNumber  Int      // 第几手操作
  playerId    String   // 玩家ID（字符串，可以是用户ID或其他标识）
  actionType  ActionType
  cards       String   // JSON 序列化数据：打出的卡牌ID数组
  
  @@map("action_logs")
}

// 操作类型枚举
enum ActionType {
  PLAY
  PASS
}